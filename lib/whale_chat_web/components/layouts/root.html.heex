<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Kogasatopia at kogasa.tf is the website for Kogasatopia | New Jersey, a Team Fortress 2 server with player stats, maps, weapon changes, custom weapons, and community pages."
    />
    <meta property="og:site_name" content="Kogasatopia" />
    <meta property="og:title" content="Kogasatopia | Kogasatopia New Jersey TF2 Server" />
    <meta
      property="og:description"
      content="Kogasatopia at kogasa.tf is the website for Kogasatopia | New Jersey, a Team Fortress 2 server with player stats, maps, weapon changes, custom weapons, and community pages."
    />
    <meta property="og:url" content="https://kogasa.tf/" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://kogasa.tf/#website",
        "url": "https://kogasa.tf/",
        "name": "Kogasatopia",
        "alternateName": ["Kogasatopia | New Jersey", "Kogasatopia New Jersey", "kogasa.tf"]
      }
    </script>
    <.live_title default="Kogasatopia" suffix=" · kogasa.tf">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link
      rel="preload"
      as="image"
      href="/stats/assets/background_product_pro.jpg"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/stats/assets/whaletracker_logo.png"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/stats/assets/wholesome2.gif"
      fetchpriority="high"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix.min.js"}>
    </script>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/phoenix_live_view.min.js"}
    >
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
