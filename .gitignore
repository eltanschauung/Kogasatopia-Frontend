# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Local notes / private explanations
.explanation.txt
project.md
phoenix_webserver_explanation.txt
AGENTS.md
.server4001.log
access.log
weaponreverts.cfg
weapons.txt
installed-packages.tsv
manual-packages.txt

# Cached assets / mirrored PHP cache directories
/priv/static/stats/cache/
/priv/static/sb/
/priv/static/**/*quickstats*.txt
/priv/static/**/mapstats_output.txt
/stats/cache/
/web/stats/cache/

# Legacy PHP/application material is not part of the Phoenix static mirror.
/priv/static/**/*.php
/priv/static/**/.htaccess
/priv/static/vendor/
/priv/static/backups/
/priv/static/stats/backup/
/priv/static/stats/logs/

# Ignore package tarball (built via "mix hex.build").
kogasa_frontend-*.tar

# Large binary/static asset ignores
# Gitignore cannot filter by file size; keep this generated list for current images over 0.2 MiB.
*.vpk
*.zip

